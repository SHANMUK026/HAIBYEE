# Server Configuration
PORT=3000
NODE_ENV=development
JWT_SECRET=your_jwt_secret_here

# Database Configuration (PostgreSQL)
# Replace with real credentials provided by user
DATABASE_URL="postgresql://user:password@localhost:5432/silvra_db?schema=public"

# OTP API Configuration
OTP_API_URL="https://api.fast2sms.com/v1/send"
OTP_API_KEY="your_fast2sms_api_key"

# Live Price API Configuration (Gold/Silver)
PRICE_API_URL="https://www.goldapi.io/api/XAU/INR"
PRICE_API_KEY="your_goldapi_key"

# Razorpay Configuration
RAZORPAY_KEY_ID="rzp_test_..."
RAZORPAY_KEY_SECRET="your_razorpay_secret"

# Surepass KYC Configuration
SUREPASS_CLIENT_ID="your_client_id"
SUREPASS_CLIENT_SECRET="your_client_secret"
